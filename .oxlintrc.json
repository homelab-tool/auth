{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "plugins": ["eslint", "typescript", "unicorn", "oxc", "import", "promise"],
    "options": {
        "typeAware": true,
        "typeCheck": true,
        "reportUnusedDisableDirectives": "error",
        "respectEslintDisableDirectives": false
    },
    "categories": {
        "correctness": "error",
        "suspicious": "error",
        "perf": "warn"
    },
    "rules": {
        "no-await-in-loop": "off"
    },
    "env": {
        "builtin": true,
        "es2026": true,
        "browser": true,
        "node": true
    }
}
