package layout

templ AdminLayout(title string) {
	@Page(title) {
		<div class="admin-container">
			<nav class="admin-sidebar">
				<h2>Admin</h2>
				<ul>
					<li><a href="/admin/groups">Groups</a></li>
					<li><a href="/admin/site-configs">Site Configs</a></li>
				</ul>
			</nav>
			<main class="admin-content">
				{ children... }
			</main>
		</div>
	}
}
