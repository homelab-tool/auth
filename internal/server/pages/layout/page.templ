package layout

templ Page(title string) {
  <!DOCTYPE html>
  <html lang="en">
    <head>
      <meta charset="utf-8"/>
      <meta name="viewport" content="width=device-width, initial-scale=1"/>
      <title>{ title }</title>
      <script src="/static/htmx.min.js"></script>
    </head>
    <body>
      <main>
        { children... }
      </main>
    </body>
  </html>
}
