package layout

import "github.com/homelab-tool/auth/internal/server/pages/static"

templ Page(title string) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="utf-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1"/>
			<title>{ title }</title>
			<script src="/static/htmx.2.0.10.js"></script>
			<link href={ static.StaticURL("main.css") } rel="stylesheet"/>
		</head>
		<body>
			<main>
				{ children... }
			</main>
		</body>
	</html>
}
